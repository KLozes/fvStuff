/* Hot colormap (black->red->yellow->white) */
static void hot_rgb(double t, unsigned char *r, unsigned char *g, unsigned char *b)
{
    if      (t < 1./3.) { *r=(unsigned char)(t*3.*255); *g=0; *b=0; }
    else if (t < 2./3.) { *r=255; *g=(unsigned char)((t-1./3.)*3.*255); *b=0; }
    else                { *r=255; *g=255; *b=(unsigned char)((t-2./3.)*3.*255); }
}

static void
write_ppm(const char *fname, const double *data, int N,
          double vmin, double vmax, int cmap)
{
    /* cmap: 0=plasma, 1=viridis, 2=hot */
    FILE *f = fopen(fname, "wb");
    if (!f) { fprintf(stderr, "Cannot open %s\n", fname); return; }
    fprintf(f, "P6\n%d %d\n255\n", N, N);

    unsigned char pix[3];
    for (int jj = N-1; jj >= 0; jj--) {          /* flip y: j=0 at bottom */
        for (int ii = 0; ii < N; ii++) {
            double t = (data[jj*N + ii] - vmin) / (vmax - vmin + 1e-30);
            if (t < 0.0) t = 0.0;
            if (t > 1.0) t = 1.0;
            int idx = (int)(t * 255.0);
            if (cmap == 0)      { pix[0]=PLASMA[idx][0]; pix[1]=PLASMA[idx][1]; pix[2]=PLASMA[idx][2]; }
            else if (cmap == 1) { pix[0]=VIRIDIS[idx][0];pix[1]=VIRIDIS[idx][1];pix[2]=VIRIDIS[idx][2];}
            else                { hot_rgb(t, &pix[0], &pix[1], &pix[2]); }
            fwrite(pix, 1, 3, f);
        }
    }
    fclose(f);
    printf("  Saved %s\n", fname);
}

/* Blue-white-red diverging colormap (for vorticity) */
static void bwr_rgb(double t, unsigned char *r, unsigned char *g, unsigned char *b)
{
    if (t < 0.5) {
        *r = (unsigned char)(t * 2.0 * 255);
        *g = (unsigned char)(t * 2.0 * 255);
        *b = 255;
    } else {
        *r = 255;
        *g = (unsigned char)((1.0 - t) * 2.0 * 255);
        *b = (unsigned char)((1.0 - t) * 2.0 * 255);
    }
}

/* Compute vorticity (dv/dx - du/dy) and velocity magnitude on GPU (grid-stride) */
__global__ void
compute_derived(const double * __restrict__ U,
                double       * __restrict__ vort,
                double       * __restrict__ vmag,
                int N, double h)
{
    int N2 = N * N;
    for (int k = blockIdx.x * blockDim.x + threadIdx.x; k < N2;
             k += blockDim.x * gridDim.x) {
    int j = k / N, i = k % N;

    /* 6th-order skew-symmetric stencil offsets and coefficients */
    const double coeff[6] = {-1., 9., -45., 45., -9., 1.};
    const int    off[6]   = {-3, -2, -1,  1,  2,  3};

    double dv_dx = 0., du_dy = 0.;
    for (int k = 0; k < 6; k++) {
        double rho_x = fetch(U, 0, j, i + off[k], N);
        rho_x = rho_x > 1e-14 ? rho_x : 1e-14;
        dv_dx += coeff[k] * (fetch(U, 2, j, i + off[k], N) / rho_x);

        double rho_y = fetch(U, 0, j + off[k], i, N);
        rho_y = rho_y > 1e-14 ? rho_y : 1e-14;
        du_dy += coeff[k] * (fetch(U, 1, j + off[k], i, N) / rho_y);
    }
    vort[j*N + i] = (dv_dx - du_dy) / (60.0 * h);

    /* velocity magnitude using centre cell */
    double rho = fetch(U, 0, j, i, N);
    rho = rho > 1e-14 ? rho : 1e-14;
    double u = fetch(U, 1, j, i, N) / rho;
    double v = fetch(U, 2, j, i, N) / rho;
    vmag[j*N + i] = sqrt(u*u + v*v);
    } /* grid-stride loop */
}

/* Write a 2N×2N composite PPM.  Layout (physical coordinates):
 *   top-left  | top-right
 *   ----------+----------
 *   bot-left  | bot-right
 * cmap: 0=plasma, 1=viridis, 2=hot, 3=bwr
 */
static void
write_ppm_2x2(const char *fname,
              const double *tl, double tl_min, double tl_max, int tl_cmap,
              const double *tr, double tr_min, double tr_max, int tr_cmap,
              const double *bl, double bl_min, double bl_max, int bl_cmap,
              const double *br, double br_min, double br_max, int br_cmap,
              int N)
{
    FILE *f = fopen(fname, "wb");
    if (!f) { fprintf(stderr, "Cannot open %s\n", fname); return; }
    fprintf(f, "P6\n%d %d\n255\n", 2*N, 2*N);

    unsigned char pix[3];
    for (int r = 0; r < 2*N; r++) {        /* r=0 is the top of the image */
        int phys_j = 2*N - 1 - r;          /* y-flip: phys_j=0 → bottom  */
        for (int c = 0; c < 2*N; c++) {
            const double *panel;
            double vmin, vmax;
            int cmap, sub_j, sub_i;

            if (phys_j >= N) {              /* top row of panels */
                sub_j = phys_j - N;
                if (c < N) { panel=tl; vmin=tl_min; vmax=tl_max; cmap=tl_cmap; sub_i=c;   }
                else        { panel=tr; vmin=tr_min; vmax=tr_max; cmap=tr_cmap; sub_i=c-N; }
            } else {                        /* bottom row of panels */
                sub_j = phys_j;
                if (c < N) { panel=bl; vmin=bl_min; vmax=bl_max; cmap=bl_cmap; sub_i=c;   }
                else        { panel=br; vmin=br_min; vmax=br_max; cmap=br_cmap; sub_i=c-N; }
            }

            double t = (panel[sub_j*N + sub_i] - vmin) / (vmax - vmin + 1e-30);
            if (t < 0.0) t = 0.0;
            if (t > 1.0) t = 1.0;
            int idx = (int)(t * 255.0);
            if      (cmap == 0) { pix[0]=PLASMA[idx][0];  pix[1]=PLASMA[idx][1];  pix[2]=PLASMA[idx][2];  }
            else if (cmap == 1) { pix[0]=VIRIDIS[idx][0]; pix[1]=VIRIDIS[idx][1]; pix[2]=VIRIDIS[idx][2]; }
            else if (cmap == 2) { hot_rgb(t, &pix[0], &pix[1], &pix[2]); }
            else                { bwr_rgb(t, &pix[0], &pix[1], &pix[2]); }
            fwrite(pix, 1, 3, f);
        }
    }
    fclose(f);
    printf("  Saved %s\n", fname);
}

/* ═══════════════════════════════════════════════════════════════════════════
 * main
 * ═══════════════════════════════════════════════════════════════════════════ */
int main(int argc, char **argv)
{
    int    N     = (argc > 1) ? atoi(argv[1]) : 400;
    double C2    = (argc > 2) ? atof(argv[2]) : 0.5;   /* Ducros D2 coeff */
    double Cg    = (argc > 3) ? atof(argv[3]) : 0.0;   /* global LF coeff */
    double sc    = (argc > 4) ? atof(argv[4]) : 0.05;
    int    order = (argc > 5) ? atoi(argv[5]) : 5;
    /* validate order: only 3, 5, 7, 9 are supported */
    if (order != 3 && order != 5 && order != 7 && order != 9) {
        fprintf(stderr, "order must be 3, 5, 7, or 9 (got %d)\n", order);
        return 1;
    }
    double CFL = 0.40, t_end = 1.0, h = 1.0 / N;

    /* GPU info */
    int dev; cudaDeviceProp prop;
    CK(cudaGetDevice(&dev));
    CK(cudaGetDeviceProperties(&prop, dev));
    printf("========================================================\n");
    printf("  Device  : %s\n", prop.name);
    printf("  UP%d+HLLC+Ducros FV 2D  --  Circular Sod\n", order);
    printf("  n=%dx%d  h=%.5f  C2=%.3f  Cg=%.4f  sc=%.4f  CFL=%.2f  order=%d\n",
           N, N, h, C2, Cg, sc, CFL, order);
    printf("========================================================\n");

    /* allocate */
    size_t sz1 = N * N * sizeof(double);
    size_t sz4 = 4 * sz1;
    double *d_U, *d_U0, *d_U1, *d_U2, *d_RHS, *d_lam, *d_tmp, *d_SD, *d_vort, *d_vmag;
    CK(cudaMalloc(&d_U,    sz4));
    CK(cudaMalloc(&d_U0,   sz4));
    CK(cudaMalloc(&d_U1,   sz4));
    CK(cudaMalloc(&d_U2,   sz4));
    CK(cudaMalloc(&d_RHS,  sz4));
    CK(cudaMalloc(&d_lam,  sz1));
    CK(cudaMalloc(&d_SD,   sz1));
    CK(cudaMalloc(&d_vort, sz1));
    CK(cudaMalloc(&d_vmag, sz1));
    /* tmp for max reduction: one partial result per GS_NBLK block */
    CK(cudaMalloc(&d_tmp, GS_NBLK * sizeof(double)));

    int  M   = 4 * N * N;

    double *h_rho  = (double*)malloc(sz1);
    double *h_p    = (double*)malloc(sz1);
    double *h_sd   = (double*)malloc(sz1);
    double *h_rhou = (double*)malloc(sz1);
    double *h_rhov = (double*)malloc(sz1);
    double *h_E    = (double*)malloc(sz1);
    double *h_vort = (double*)malloc(sz1);
    double *h_vmag = (double*)malloc(sz1);

    /* ── helper: download fields, compute pressure, write 3 PPMs ──────── */
    /* color scale fixed to IC extremes for temporal consistency           */
    const double RHO_MIN = 0.125, RHO_MAX = 10.1;

    /* local lambda via nested function trick — use a macro instead */
#define WRITE_FRAME(frame_idx) do { \
    CK(cudaMemcpy(h_rho,  d_U + 0*N*N, sz1, cudaMemcpyDeviceToHost)); \
    CK(cudaMemcpy(h_rhou, d_U + 1*N*N, sz1, cudaMemcpyDeviceToHost)); \
    CK(cudaMemcpy(h_rhov, d_U + 2*N*N, sz1, cudaMemcpyDeviceToHost)); \
    CK(cudaMemcpy(h_E,    d_U + 3*N*N, sz1, cudaMemcpyDeviceToHost)); \
    compute_sensor <<<GS_NBLK, BLOCK1D>>>(d_U, d_SD,   N, h, sc); \
    compute_derived<<<GS_NBLK, BLOCK1D>>>(d_U, d_vort, d_vmag, N, h); \
    CK(cudaDeviceSynchronize()); \
    CK(cudaMemcpy(h_sd,   d_SD,   sz1, cudaMemcpyDeviceToHost)); \
    CK(cudaMemcpy(h_vort, d_vort, sz1, cudaMemcpyDeviceToHost)); \
    CK(cudaMemcpy(h_vmag, d_vmag, sz1, cudaMemcpyDeviceToHost)); \
    for (int _k = 0; _k < N*N; _k++) { \
        double _u = h_rhou[_k]/h_rho[_k], _v = h_rhov[_k]/h_rho[_k]; \
        h_p[_k] = (GAMMA_V-1.)*(h_E[_k] - 0.5*(h_rhou[_k]*_u + h_rhov[_k]*_v)); \
    } \
    /* symmetric vorticity color range */ \
    double _wmax = 1e-10; \
    for (int _k = 0; _k < N*N; _k++) { \
        double _aw = h_vort[_k] < 0.0 ? -h_vort[_k] : h_vort[_k]; \
        if (_aw > _wmax) _wmax = _aw; \
    } \
    /* velocity magnitude range 0..max */ \
    double _vmax = 1e-10; \
    for (int _k = 0; _k < N*N; _k++) \
        if (h_vmag[_k] > _vmax) _vmax = h_vmag[_k]; \
    char _fn[64]; \
    sprintf(_fn, "sod_%04d.ppm", (frame_idx)); \
    write_ppm_2x2(_fn, \
        h_rho,  RHO_MIN, RHO_MAX, 0, \
        h_vort, -_wmax,  _wmax,   3, \
        h_sd,   0.0,     1.0,     2, \
        h_vmag, 0.0,     _vmax,   1, \
        N); \
} while(0)

    /* IC */
    ic_kernel<<<GS_NBLK, BLOCK1D>>>(d_U, N, h);
    CK(cudaDeviceSynchronize());

    /* frame 0 at t=0 */
    WRITE_FRAME(0);

    /* time loop */
    const int  N_FRAMES  = 10;
    int    frame     = 1;
    double t_next    = t_end / N_FRAMES;    /* next frame target time */
    int    step = 0;
    double t    = 0.0;
    struct timespec ts0, ts1;
    clock_gettime(CLOCK_MONOTONIC, &ts0);

    while (t < t_end) {
        /* compute RHS + lam_max to get dt */
        compute_rhs<<<GS_NBLK, BLOCK1D>>>(d_U, d_RHS, d_lam, N, h, C2, Cg, sc, order);
        double lam_max = gpu_max(d_lam, d_tmp, N*N);
        double dt = CFL * h / lam_max;
        /* clamp to next frame boundary or t_end, whichever is closer */
        double t_target = (t_next < t_end) ? t_next : t_end;
        if (t + dt > t_target) dt = t_target - t;
        if (dt < 1e-14) break;

        /* SSP-RK3 */
        CK(cudaMemcpy(d_U0, d_U, sz4, cudaMemcpyDeviceToDevice));

        /* stage 1: U1 = U0 + dt*L(U0)   [RHS already in d_RHS] */
        rk3_s1<<<GS_NBLK, BLOCK1D>>>(d_U1, d_U0, d_RHS, dt, M);

        /* stage 2 */
        compute_rhs<<<GS_NBLK, BLOCK1D>>>(d_U1, d_RHS, d_lam, N, h, C2, Cg, sc, order);
        rk3_s2<<<GS_NBLK, BLOCK1D>>>(d_U2, d_U0, d_U1, d_RHS, dt, M);

        /* stage 3 */
        compute_rhs<<<GS_NBLK, BLOCK1D>>>(d_U2, d_RHS, d_lam, N, h, C2, Cg, sc, order);
        rk3_s3<<<GS_NBLK, BLOCK1D>>>(d_U, d_U0, d_U2, d_RHS, dt, M);

        t += dt; step++;

        /* check frame boundary */
        if (t >= t_next - 1e-12 && frame <= N_FRAMES) {
            clock_gettime(CLOCK_MONOTONIC, &ts1);
            double el = (ts1.tv_sec-ts0.tv_sec)+(ts1.tv_nsec-ts0.tv_nsec)*1e-9;
            printf("  frame %2d/%d  step %5d  t=%.5f  elapsed=%.1fs\n",
                   frame, N_FRAMES, step, t, el);
            fflush(stdout);
            WRITE_FRAME(frame);
            frame++;
            t_next = frame * t_end / N_FRAMES;
        } else if (step % 50 == 0) {
            clock_gettime(CLOCK_MONOTONIC, &ts1);
            double el = (ts1.tv_sec-ts0.tv_sec)+(ts1.tv_nsec-ts0.tv_nsec)*1e-9;
            double eta = (t > 0) ? (t_end-t)/t*el : 0;
            printf("  step %5d  t=%.5f  dt=%.3e  elapsed=%.1fs  ETA=%.0fs\n",
                   step, t, dt, el, eta);
            fflush(stdout);
        }
    }
    CK(cudaDeviceSynchronize());
    clock_gettime(CLOCK_MONOTONIC, &ts1);
    double wall = (ts1.tv_sec-ts0.tv_sec)+(ts1.tv_nsec-ts0.tv_nsec)*1e-9;
    printf("  Done: %d steps,  t=%.6f,  wall=%.2fs\n", step, t, wall);
    printf("  Frames written: sod_0000.ppm .. sod_%04d.ppm  (2x2 composite)\n", N_FRAMES);

    /* cleanup */
    free(h_rho); free(h_p); free(h_sd);
    free(h_rhou); free(h_rhov); free(h_E);
    free(h_vort); free(h_vmag);
    cudaFree(d_U); cudaFree(d_U0); cudaFree(d_U1); cudaFree(d_U2);
    cudaFree(d_RHS); cudaFree(d_lam); cudaFree(d_tmp); cudaFree(d_SD);
    cudaFree(d_vort); cudaFree(d_vmag);
    return 0;
}
