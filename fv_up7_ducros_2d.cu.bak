/*
 * fv_up7_ducros_2d.cu
 * 2D Circular Sod — FV: UP7 + HLLC + Ducros D2 AV, SSP-RK3
 *
 * Compile:
 *   nvcc -O3 -arch=sm_80 -o fv_up7 fv_up7_ducros_2d.cu -lm
 *   (replace sm_80 with your GPU arch, e.g. sm_86, sm_89, sm_90)
 *
 * Run:
 *   ./fv_up7            # n=400
 *   ./fv_up7 600 0.5 0.01
 *
 * Output:
 *   sod_rho.ppm   — density field  (plasma colormap)
 *   sod_p.ppm     — pressure field (viridis colormap)
 *   sod_sd.ppm    — Ducros sensor  (hot colormap)
 */

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <string.h>
#include <time.h>
#include <cuda_runtime.h>

/* ── compile-time constants ─────────────────────────────────────────────── */
#define GAMMA_V  1.4
#define BLOCK1D  256         /* threads per block */
#define GS_NBLK  256         /* fixed grid size for all grid-stride kernels */

/* ── CUDA error check ───────────────────────────────────────────────────── */
#define CK(x) do { \
    cudaError_t _e = (x); \
    if (_e != cudaSuccess) { \
        fprintf(stderr, "CUDA error at %s:%d: %s\n", \
                __FILE__, __LINE__, cudaGetErrorString(_e)); \
        exit(1); \
    } \
} while (0)

/* ── Array indexing: SoA layout U[q][j][i] ─────────────────────────────── */
/* q = conserved variable (0=rho,1=rhou,2=rhov,3=E), j=row(y), i=col(x)   */
#define IDX(q,j,i,N)  ((q)*(N)*(N) + (j)*(N) + (i))

/* ═══════════════════════════════════════════════════════════════════════════
 * Device helpers
 * ═══════════════════════════════════════════════════════════════════════════ */

/* Wall-reflecting ghost-cell fetch */
__device__ __forceinline__ double
fetch(const double * __restrict__ U, int q, int j, int i, int N)
{
    double sx = 1.0, sy = 1.0;
    if      (i <  0) { i  = -1 - i;      sx = -1.0; }
    else if (i >= N) { i  = 2*N - 1 - i; sx = -1.0; }
    if      (j <  0) { j  = -1 - j;      sy = -1.0; }
    else if (j >= N) { j  = 2*N - 1 - j; sy = -1.0; }
    double v = U[IDX(q, j, i, N)];
    if (q == 1) v *= sx;
    if (q == 2) v *= sy;
    return v;
}

/* Primitive variables from conserved */
__device__ __forceinline__ void
prim4(double rho, double rhou, double rhov, double E,
      double *p, double *c, double *u, double *v)
{
    *u  = rhou / rho;
    *v  = rhov / rho;
    *p  = (GAMMA_V - 1.0) * (E - 0.5*(rhou*(*u) + rhov*(*v)));
    double cs2 = GAMMA_V * (*p) / rho;
    *c  = sqrt(cs2 > 1e-14 ? cs2 : 1e-14);
}

/* 2-D spectral radius (for CFL) */
__device__ __forceinline__ double
lambda(double rho, double rhou, double rhov, double E)
{
    double p, c, u, v;
    prim4(rho, rhou, rhov, E, &p, &c, &u, &v);
    return fabs(u) + fabs(v) + c;
}

/* Directional wave speeds (for dissipation scaling) */
__device__ __forceinline__ double
lambda_x(double rho, double rhou, double rhov, double E)
{
    double p, c, u, v;
    prim4(rho, rhou, rhov, E, &p, &c, &u, &v);
    return fabs(u) + c;
}
__device__ __forceinline__ double
lambda_y(double rho, double rhou, double rhov, double E)
{
    double p, c, u, v;
    prim4(rho, rhou, rhov, E, &p, &c, &u, &v);
    return fabs(v) + c;
}

/* ── Upwind reconstructions at i+½ ─────────────────────────────────────── */
/*  All stencils are left-biased for vL (upwind) and right-biased for vR.  */

/* UP3  stencil[0..3] = [i-2, i-1, i, i+1]                                */
__device__ __forceinline__ void
up3(const double s[4], double *vL, double *vR)
{
    *vL = (-s[0] + 5.0*s[1] + 2.0*s[2]) / 6.0;
    *vR = ( 2.0*s[1] + 5.0*s[2] - s[3]) / 6.0;
}

/* UP5  stencil[0..5] = [i-3, i-2, i-1, i, i+1, i+2]                      */
__device__ __forceinline__ void
up5(const double s[6], double *vL, double *vR)
{
    *vL = (  2.0*s[0] - 13.0*s[1] + 47.0*s[2]
           + 27.0*s[3] -  3.0*s[4]) / 60.0;
    *vR = ( -3.0*s[1] + 27.0*s[2] + 47.0*s[3]
           - 13.0*s[4] +  2.0*s[5]) / 60.0;
}

/* UP7  stencil[0..7] = [i-4, i-3, i-2, i-1, i, i+1, i+2, i+3]            */
__device__ __forceinline__ void
up7(const double s[8], double *vL, double *vR)
{
    *vL = (-3.0*s[0] + 25.0*s[1] - 101.0*s[2] + 319.0*s[3]
           + 214.0*s[4] - 38.0*s[5] + 4.0*s[6]) / 420.0;
    *vR = (4.0*s[1] - 38.0*s[2] + 214.0*s[3] + 319.0*s[4]
           - 101.0*s[5] + 25.0*s[6] - 3.0*s[7]) / 420.0;
}

/* UP9  stencil[0..9] = [i-5, i-4, i-3, i-2, i-1, i, i+1, i+2, i+3, i+4] */
__device__ __forceinline__ void
up9(const double s[10], double *vL, double *vR)
{
    *vL = (  3.0*s[0] -  25.0*s[1] + 101.0*s[2] - 319.0*s[3]
           + 2765.0*s[4] + 2139.0*s[5] - 533.0*s[6]
           + 97.0*s[7] -  11.0*s[8]) / 2520.0;
    *vR = (-11.0*s[1] +  97.0*s[2] - 533.0*s[3] + 2139.0*s[4]
           + 2765.0*s[5] - 319.0*s[6] + 101.0*s[7]
           -  25.0*s[8] +   3.0*s[9]) / 2520.0;
}

/* ── Runtime dispatch: select reconstruction based on order ─────────────── */
/* stencil s[0..sw-1] = cells [i-g .. i-g+sw-1] for the left interface     */
__device__ __forceinline__ void
up_recon(int order, const double s[10], double *vL, double *vR)
{
    if      (order == 3) up3(s, vL, vR);
    else if (order == 5) up5(s, vL, vR);
    else if (order == 9) up9(s, vL, vR);
    else                 up7(s, vL, vR);   /* order==7: s[0..7] */
}

/* ── HLLE flux in x ─────────────────────────────────────────────────────── */
__device__ void
hlle_x(const double UL[4], const double UR[4], double F[4])
{
    double pL, cL, uL, vL, pR, cR, uR, vR;
    prim4(UL[0],UL[1],UL[2],UL[3], &pL,&cL,&uL,&vL);
    prim4(UR[0],UR[1],UR[2],UR[3], &pR,&cR,&uR,&vR);

    double FL[4] = { UL[1], UL[1]*uL+pL, UL[1]*vL, (UL[3]+pL)*uL };
    double FR[4] = { UR[1], UR[1]*uR+pR, UR[1]*vR, (UR[3]+pR)*uR };

    double SL = fmin(uL-cL, uR-cR);
    double SR = fmax(uL+cL, uR+cR);
    double dS = fmax(SR-SL, 1e-10);

    if      (SL >= 0.0) { for (int q=0;q<4;q++) F[q] = FL[q]; }
    else if (SR <= 0.0) { for (int q=0;q<4;q++) F[q] = FR[q]; }
    else {
        for (int q=0;q<4;q++)
            F[q] = (SR*FL[q] - SL*FR[q] + SR*SL*(UR[q]-UL[q])) / dS;
    }
}

/* ── HLLE flux in y ─────────────────────────────────────────────────────── */
__device__ void
hlle_y(const double UL[4], const double UR[4], double G[4])
{
    double pL, cL, uL, vL, pR, cR, uR, vR;
    prim4(UL[0],UL[1],UL[2],UL[3], &pL,&cL,&uL,&vL);
    prim4(UR[0],UR[1],UR[2],UR[3], &pR,&cR,&uR,&vR);

    double GL[4] = { UL[2], UL[2]*uL, UL[2]*vL+pL, (UL[3]+pL)*vL };
    double GR[4] = { UR[2], UR[2]*uR, UR[2]*vR+pR, (UR[3]+pR)*vR };

    double SL = fmin(vL-cL, vR-cR);
    double SR = fmax(vL+cL, vR+cR);
    double dS = fmax(SR-SL, 1e-10);

    if      (SL >= 0.0) { for (int q=0;q<4;q++) G[q] = GL[q]; }
    else if (SR <= 0.0) { for (int q=0;q<4;q++) G[q] = GR[q]; }
    else {
        for (int q=0;q<4;q++)
            G[q] = (SR*GL[q] - SL*GR[q] + SR*SL*(UR[q]-UL[q])) / dS;
    }
}

/* ── HLLC flux in x ─────────────────────────────────────────────────────── */
__device__ void
hllc_x(const double UL[4], const double UR[4], double F[4])
{
    double pL, cL, uL, vL, pR, cR, uR, vR;
    prim4(UL[0],UL[1],UL[2],UL[3], &pL,&cL,&uL,&vL);
    prim4(UR[0],UR[1],UR[2],UR[3], &pR,&cR,&uR,&vR);

    double SL = fmin(uL-cL, uR-cR);
    double SR = fmax(uL+cL, uR+cR);

    if (SL >= 0.0) {
        F[0]=UL[1]; F[1]=UL[1]*uL+pL; F[2]=UL[1]*vL; F[3]=(UL[3]+pL)*uL;
        return;
    }
    if (SR <= 0.0) {
        F[0]=UR[1]; F[1]=UR[1]*uR+pR; F[2]=UR[1]*vR; F[3]=(UR[3]+pR)*uR;
        return;
    }

    /* contact speed */
    double dL = UL[0]*(SL-uL), dR = UR[0]*(SR-uR);
    double Ss = (pR - pL + dL*uL - dR*uR) / (dL - dR);

    /* pick star state on the correct side of contact */
    const double *UK  = (Ss >= 0.0) ? UL : UR;
    double pK   = (Ss >= 0.0) ? pL  : pR;
    double uK   = (Ss >= 0.0) ? uL  : uR;
    double vK   = (Ss >= 0.0) ? vL  : vR;
    double SK   = (Ss >= 0.0) ? SL  : SR;
    double fact = UK[0] * (SK - uK) / (SK - Ss);

    double Us[4];
    Us[0] = fact;
    Us[1] = fact * Ss;
    Us[2] = fact * vK;
    Us[3] = fact * (UK[3]/UK[0] + (Ss - uK)*(Ss + pK/(UK[0]*(SK - uK))));

    /* FK + SK*(U*K - UK) */
    double FK[4] = { UK[1], UK[1]*uK+pK, UK[1]*vK, (UK[3]+pK)*uK };
    for (int q = 0; q < 4; q++) F[q] = FK[q] + SK*(Us[q] - UK[q]);
}

/* ── HLLC flux in y ─────────────────────────────────────────────────────── */
__device__ void
hllc_y(const double UL[4], const double UR[4], double G[4])
{
    double pL, cL, uL, vL, pR, cR, uR, vR;
    prim4(UL[0],UL[1],UL[2],UL[3], &pL,&cL,&uL,&vL);
    prim4(UR[0],UR[1],UR[2],UR[3], &pR,&cR,&uR,&vR);

    double SL = fmin(vL-cL, vR-cR);
    double SR = fmax(vL+cL, vR+cR);

    if (SL >= 0.0) {
        G[0]=UL[2]; G[1]=UL[2]*uL; G[2]=UL[2]*vL+pL; G[3]=(UL[3]+pL)*vL;
        return;
    }
    if (SR <= 0.0) {
        G[0]=UR[2]; G[1]=UR[2]*uR; G[2]=UR[2]*vR+pR; G[3]=(UR[3]+pR)*vR;
        return;
    }

    double dL = UL[0]*(SL-vL), dR = UR[0]*(SR-vR);
    double Ss = (pR - pL + dL*vL - dR*vR) / (dL - dR);

    const double *UK  = (Ss >= 0.0) ? UL : UR;
    double pK   = (Ss >= 0.0) ? pL  : pR;
    double uK   = (Ss >= 0.0) ? uL  : uR;
    double vK   = (Ss >= 0.0) ? vL  : vR;
    double SK   = (Ss >= 0.0) ? SL  : SR;
    double fact = UK[0] * (SK - vK) / (SK - Ss);

    double Us[4];
    Us[0] = fact;
    Us[1] = fact * uK;
    Us[2] = fact * Ss;
    Us[3] = fact * (UK[3]/UK[0] + (Ss - vK)*(Ss + pK/(UK[0]*(SK - vK))));

    double GK[4] = { UK[2], UK[2]*uK, UK[2]*vK+pK, (UK[3]+pK)*vK };
    for (int q = 0; q < 4; q++) G[q] = GK[q] + SK*(Us[q] - UK[q]);
}

/* ═══════════════════════════════════════════════════════════════════════════
 * Main RHS kernel  (grid-stride)
 * ═══════════════════════════════════════════════════════════════════════════ */
__global__ void
compute_rhs(const double * __restrict__ U,
            double       * __restrict__ RHS,
            double       * __restrict__ lam_out,
            int N, double h, double C2, double Cg, double sc, int order)
{
    /* g = stencil half-width (cells upwind of interface):
       order 3 → g=2, 5 → g=3, 7 → g=4, 9 → g=5              */
    const int g  = (order + 1) / 2;   /* half-widths: 2,3,4,5  */
    const int sw = 2 * g;             /* stencil width: 4,6,8,10 */

    int N2 = N * N;
    for (int k = blockIdx.x * blockDim.x + threadIdx.x; k < N2;
             k += blockDim.x * gridDim.x) {
    int j = k / N, i = k % N;

    /* ── 10-slot stencil buffer (max UP9 width); fill only sw entries ── */
    double s[10];

    /* x−½  (cells i-g..i+(sw-g-1)) */
    double ULm[4], URm[4];
    for (int q = 0; q < 4; q++) {
        for (int d = 0; d < sw; d++) s[d] = fetch(U, q, j, i-g+d, N);
        up_recon(order, s, &ULm[q], &URm[q]);
    }
    double Fm[4];  hllc_x(ULm, URm, Fm);

    /* x+½  (cells i-g+1..i+sw-g) */
    double ULp[4], URp[4];
    for (int q = 0; q < 4; q++) {
        for (int d = 0; d < sw; d++) s[d] = fetch(U, q, j, i-g+1+d, N);
        up_recon(order, s, &ULp[q], &URp[q]);
    }
    double Fp[4];  hllc_x(ULp, URp, Fp);

    /* y−½  (cells j-g..j+(sw-g-1)) */
    double VLm[4], VRm[4];
    for (int q = 0; q < 4; q++) {
        for (int d = 0; d < sw; d++) s[d] = fetch(U, q, j-g+d, i, N);
        up_recon(order, s, &VLm[q], &VRm[q]);
    }
    double Gm[4];  hllc_y(VLm, VRm, Gm);

    /* y+½  (cells j-g+1..j+sw-g) */
    double VLp[4], VRp[4];
    for (int q = 0; q < 4; q++) {
        for (int d = 0; d < sw; d++) s[d] = fetch(U, q, j-g+1+d, i, N);
        up_recon(order, s, &VLp[q], &VRp[q]);
    }
    double Gp[4];  hllc_y(VLp, VRp, Gp);

    /* ── center-cell primitives ─────────────────────────────────────── */
    double p0, c0, u0, v0;
    prim4(fetch(U,0,j,i,N), fetch(U,1,j,i,N),
          fetch(U,2,j,i,N), fetch(U,3,j,i,N), &p0,&c0,&u0,&v0);

    /* ── Ducros sensor: 6th-order skew divergence ───────────────────── */
    const double wc[6] = { -1., 9., -45., 45., -9., 1. };
    const int    wo[6] = { -3, -2, -1, 1, 2, 3 };
    double du_dx = 0., dv_dy = 0.;
    for (int m = 0; m < 6; m++) {
        double rx = fetch(U,0,j,i+wo[m],N); rx = rx>1e-14?rx:1e-14;
        du_dx += wc[m] * (fetch(U,1,j,i+wo[m],N) / rx);
        double ry = fetch(U,0,j+wo[m],i,N); ry = ry>1e-14?ry:1e-14;
        dv_dy += wc[m] * (fetch(U,2,j+wo[m],i,N) / ry);
    }
    du_dx /= 60.*h;  dv_dy /= 60.*h;
    double div_u = du_dx + dv_dy;
    if (div_u > 0.) div_u = 0.;
    double sos2 = (sc/(h*h)) * c0*c0;
    double S_D  = (div_u*div_u) / (div_u*div_u + sos2 + 1e-40);

    /* ── D2 artificial viscosity: fetch ±1 neighbors directly ──────── */
    /* Use directional wave speeds: |u|+c for x-faces, |v|+c for y-faces */
    double lam_c   = fabs(u0) + fabs(v0) + c0;   /* 2-D spectral radius for CFL */
    double lamx_c  = fabs(u0) + c0;
    double lamy_c  = fabs(v0) + c0;
    double lhxp = 0.5*(lamx_c + lambda_x(fetch(U,0,j,i+1,N),fetch(U,1,j,i+1,N),fetch(U,2,j,i+1,N),fetch(U,3,j,i+1,N)));
    double lhxm = 0.5*(lamx_c + lambda_x(fetch(U,0,j,i-1,N),fetch(U,1,j,i-1,N),fetch(U,2,j,i-1,N),fetch(U,3,j,i-1,N)));
    double lhyp = 0.5*(lamy_c + lambda_y(fetch(U,0,j+1,i,N),fetch(U,1,j+1,i,N),fetch(U,2,j+1,i,N),fetch(U,3,j+1,i,N)));
    double lhym = 0.5*(lamy_c + lambda_y(fetch(U,0,j-1,i,N),fetch(U,1,j-1,i,N),fetch(U,2,j-1,i,N),fetch(U,3,j-1,i,N)));

    double D2[4];
    for (int q = 0; q < 4; q++) {
        double Uc  = fetch(U,q,j,  i,  N);
        double Uxp = fetch(U,q,j,  i+1,N), Uxm = fetch(U,q,j,  i-1,N);
        double Uyp = fetch(U,q,j+1,i,  N), Uym = fetch(U,q,j-1,i,  N);
        double dxp = Uxp-Uc, dxm = Uc-Uxm, dyp = Uyp-Uc, dym = Uc-Uym;
        /* Ducros-gated D2: active at shocks (S_D → 1) */
        double d2_duc = (C2/h) * (lhxp*S_D*dxp - lhxm*S_D*dxm
                                + lhyp*S_D*dyp - lhym*S_D*dym);
        /* Global LF D2: active in smooth regions (1 - S_D → 1) */
        double d2_glb = (Cg/h) * (lhxp*(1.-S_D)*dxp - lhxm*(1.-S_D)*dxm
                                + lhyp*(1.-S_D)*dyp - lhym*(1.-S_D)*dym);
        D2[q] = d2_duc + d2_glb;
    }

    /* ── assemble ─────────────────────────────────────────────────────── */
    for (int q = 0; q < 4; q++)
        RHS[IDX(q,j,i,N)] = -(Fp[q]-Fm[q])/h - (Gp[q]-Gm[q])/h + D2[q];

    lam_out[j*N + i] = lam_c;
    } /* grid-stride loop */
}

/* ── sensor-only kernel (post-processing, grid-stride) ────────────────── */
__global__ void
compute_sensor(const double * __restrict__ U,
               double       * __restrict__ SD,
               int N, double h, double sc)
{
    int N2 = N * N;
    for (int k = blockIdx.x * blockDim.x + threadIdx.x; k < N2;
             k += blockDim.x * gridDim.x) {
    int j = k / N, i = k % N;

    double p0, c0, u0, v0;
    prim4(fetch(U,0,j,i,N), fetch(U,1,j,i,N),
          fetch(U,2,j,i,N), fetch(U,3,j,i,N), &p0,&c0,&u0,&v0);

    double u_s[7], v_s[7];
    for (int k = 0; k < 7; k++) {
        double r;
        r = fetch(U,0,j,i+k-3,N); r = r>1e-14?r:1e-14;
        u_s[k] = fetch(U,1,j,i+k-3,N) / r;
        r = fetch(U,0,j+k-3,i,N); r = r>1e-14?r:1e-14;
        v_s[k] = fetch(U,2,j+k-3,i,N) / r;
    }
    double coeff[6]={-1.,9.,-45.,45.,-9.,1.};
    int cidx[6]={0,1,2,4,5,6};
    double du_dx=0., dv_dy=0.;
    for (int k=0;k<6;k++){
        du_dx += coeff[k]*u_s[cidx[k]];
        dv_dy += coeff[k]*v_s[cidx[k]];
    }
    du_dx /= 60.*h; dv_dy /= 60.*h;
    double div_u = du_dx+dv_dy;
    if (div_u>0.) div_u=0.;
    double sos2 = (sc/(h*h))*c0*c0;
    SD[j*N+i] = (div_u*div_u)/(div_u*div_u+sos2+1e-40);
    } /* grid-stride loop */
}

/* ═══════════════════════════════════════════════════════════════════════════
 * SSP-RK3 update kernels  (grid-stride)
 * ═══════════════════════════════════════════════════════════════════════════ */
__global__ void rk3_s1(double*U1,const double*U0,const double*L,double dt,int M){
    for(int k=blockIdx.x*blockDim.x+threadIdx.x; k<M; k+=blockDim.x*gridDim.x)
        U1[k]=U0[k]+dt*L[k]; }

__global__ void rk3_s2(double*U2,const double*U0,const double*U1,
                       const double*L,double dt,int M){
    for(int k=blockIdx.x*blockDim.x+threadIdx.x; k<M; k+=blockDim.x*gridDim.x)
        U2[k]=0.75*U0[k]+0.25*(U1[k]+dt*L[k]); }

__global__ void rk3_s3(double*U,const double*U0,const double*U2,
                       const double*L,double dt,int M){
    for(int k=blockIdx.x*blockDim.x+threadIdx.x; k<M; k+=blockDim.x*gridDim.x)
        U[k]=(1./3.)*U0[k]+(2./3.)*(U2[k]+dt*L[k]); }

/* ── max reduction (grid-stride two-pass) ──────────────────────────────── */
__global__ void reduce_max(const double*in, double*out, int n){
    extern __shared__ double sm[];
    int tid = threadIdx.x;
    double v = 0.;
    for (int k = blockIdx.x*blockDim.x + tid; k < n; k += blockDim.x*gridDim.x)
        v = fmax(v, in[k]);
    sm[tid] = v; __syncthreads();
    for (int s = BLOCK1D/2; s > 0; s >>= 1){
        if (tid < s) sm[tid] = fmax(sm[tid], sm[tid+s]);
        __syncthreads();
    }
    if (tid == 0) out[blockIdx.x] = sm[0];
}

static double gpu_max(const double*d_in, double*d_tmp, int n){
    reduce_max<<<GS_NBLK,BLOCK1D,BLOCK1D*sizeof(double)>>>(d_in,d_tmp,n);
    reduce_max<<<1,BLOCK1D,BLOCK1D*sizeof(double)>>>(d_tmp,d_tmp,GS_NBLK);
    double v; CK(cudaMemcpy(&v,d_tmp,sizeof(double),cudaMemcpyDeviceToHost));
    return v;
}

/* ═══════════════════════════════════════════════════════════════════════════
 * IC kernel  (grid-stride)
 * ═══════════════════════════════════════════════════════════════════════════ */
__global__ void
ic_kernel(double*U, int N, double h)
{
    int N2 = N * N;
    for (int k = blockIdx.x * blockDim.x + threadIdx.x; k < N2;
             k += blockDim.x * gridDim.x) {
    int j = k / N, i = k % N;

    double xc=(i+0.5)*h, yc=(j+0.5)*h;
    double r=sqrt((xc-0.5)*(xc-0.5)+(yc-0.5)*(yc-0.5));
    double delta=1.0*h;
    double phi=0.5*(1.+tanh((0.25-r)/delta));
    double rho=0.125+9.875*phi;
    double p  =0.1  +9.9  *phi;
    U[IDX(0,j,i,N)]=rho;
    U[IDX(1,j,i,N)]=0.;
    U[IDX(2,j,i,N)]=0.;
    U[IDX(3,j,i,N)]=p/(GAMMA_V-1.);
    } /* grid-stride loop */
}

